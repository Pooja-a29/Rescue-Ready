{
  "functions": [
    {
      "source": "functions",
      "predeploy": [],
      "codebase": "default"
    },
    {
      "source": "rr-fun",
      "codebase": "rr-fun",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint"
      ]
    }
  ],
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"]
  }
}
